{
    "manifest_version": 3,
    "name": "Study Helper",
    "version": "1.0",
    "description": "A tool to help you study by finding explanations for questions.",
    "permissions": ["activeTab", "scripting", "storage"],
    "host_permissions": ["https://integrate.api.nvidia.com/*"],
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "icon.png"
      }
    },
    "background": {
      "service_worker": "background.js"
    }
  }
